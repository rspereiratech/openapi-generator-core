root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4
max_line_length = 120

[*.java]
indent_size = 4
continuation_indent_size = 8

[*.{xml,pom}]
indent_size = 4

[*.{yml,yaml}]
indent_size = 2

[*.{json,json5}]
indent_size = 2

[*.md]
indent_size = 2
trim_trailing_whitespace = false
max_line_length = off

[*.{sh,bash}]
indent_size = 2

[Makefile]
indent_style = tab

[{LICENSE,LICENSE.*,CODEOWNERS}]
insert_final_newline = true
trim_trailing_whitespace = true
